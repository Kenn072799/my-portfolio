# Copy this file to .env and fill in your values

# Backend API base URL
VITE_API_URL=https://localhost:7197

# Admin panel API key (must match AdminApiKey in backend appsettings)
VITE_ADMIN_API_KEY=your_admin_api_key_here

# Contact
VITE_EMAIL=your_email@example.com

# Social Links
VITE_GITHUB_URL=https://github.com/your-username
VITE_LINKEDIN_URL=https://www.linkedin.com/in/your-profile/
VITE_FACEBOOK_URL=https://www.facebook.com/your-profile/
